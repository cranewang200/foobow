generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            BigInt    @id @default(autoincrement())
  publicId      String    @unique @map("public_id")
  email         String?   @unique
  displayName   String    @map("display_name")
  locale        String    @default("en")
  timezone      String    @default("America/Toronto")
  accountStatus String    @default("registered") @map("account_status")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  profile        Profile?
  checkins       MoodCheckin[]
  deedActions    DeedAction[]
  focusSessions  FocusSession[]
  focusReflections FocusReflection[]
  karmaEvents    KarmaEvent[]
  journalEntries JournalEntry[]
  blessings      Blessing[]
  blessingReactions BlessingReaction[]
  donations      Donation[]
  subscriptions  Subscription[]
  safetyReports  SafetyReport[]

  @@map("users")
}

model Profile {
  id                     BigInt   @id @default(autoincrement())
  publicId               String   @unique @map("public_id")
  userId                 BigInt   @unique @map("user_id")
  avatarKey              String?  @map("avatar_key")
  bio                    String?
  privacyMode            String   @default("private") @map("privacy_mode")
  quietRankingEnabled    Boolean  @default(true) @map("quiet_ranking_enabled")
  themePreference        String   @default("system") @map("theme_preference")
  notificationPreference String   @default("daily") @map("notification_preference")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([privacyMode])
  @@map("profiles")
}

model DeedType {
  id                  BigInt   @id @default(autoincrement())
  slug                String   @unique
  name                String
  category            String
  description         String
  ritualInstructions  String   @map("ritual_instructions")
  defaultKarmaPoints  BigInt   @default(1) @map("default_karma_points")
  status              String   @default("active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  checkins    MoodCheckin[]
  deedActions DeedAction[]

  @@index([category, status])
  @@map("deed_types")
}

model MapSpot {
  id         BigInt   @id @default(autoincrement())
  slug       String   @unique
  name       String
  category   String
  latitude   Float
  longitude  Float
  region     String
  story      String
  status     String   @default("active")
  campaignId BigInt?  @map("campaign_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  campaign    DonationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  deedActions DeedAction[]

  @@index([category, status])
  @@index([campaignId])
  @@map("map_spots")
}

model MoodCheckin {
  id                    BigInt   @id @default(autoincrement())
  publicId              String   @unique @map("public_id")
  userId                BigInt   @map("user_id")
  mood                  String
  note                  String?
  checkedInOn           DateTime @map("checked_in_on") @db.Date
  recommendedDeedTypeId BigInt?  @map("recommended_deed_type_id")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendedDeedType DeedType? @relation(fields: [recommendedDeedTypeId], references: [id], onDelete: SetNull)

  @@unique([userId, checkedInOn])
  @@index([userId, checkedInOn])
  @@index([recommendedDeedTypeId])
  @@map("mood_checkins")
}

model DeedAction {
  id          BigInt    @id @default(autoincrement())
  publicId    String    @unique @map("public_id")
  userId      BigInt    @map("user_id")
  deedTypeId  BigInt    @map("deed_type_id")
  mapSpotId   BigInt?   @map("map_spot_id")
  status      String    @default("started")
  visibility  String    @default("private")
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deedType    DeedType     @relation(fields: [deedTypeId], references: [id], onDelete: Restrict)
  mapSpot     MapSpot?     @relation(fields: [mapSpotId], references: [id], onDelete: SetNull)
  karmaEvents KarmaEvent[]
  journals    JournalEntry[]
  focusSessions FocusSession[]

  @@index([userId, completedAt])
  @@index([deedTypeId, completedAt])
  @@index([mapSpotId, completedAt])
  @@map("deed_actions")
}

model KarmaEvent {
  id           BigInt   @id @default(autoincrement())
  publicId     String   @unique @map("public_id")
  userId       BigInt   @map("user_id")
  deedActionId BigInt?  @map("deed_action_id")
  focusSessionId BigInt? @map("focus_session_id")
  eventType    String   @map("event_type")
  points       BigInt
  reason       String
  sourceType   String?  @map("source_type")
  sourcePublicId String? @map("source_public_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deedAction DeedAction? @relation(fields: [deedActionId], references: [id], onDelete: SetNull)
  focusSession FocusSession? @relation(fields: [focusSessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([deedActionId])
  @@index([focusSessionId])
  @@unique([sourceType, sourcePublicId])
  @@map("karma_events")
}

model FocusSoundscape {
  id          BigInt   @id @default(autoincrement())
  slug        String   @unique
  name        String
  category    String
  description String
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  focusSessions FocusSession[]

  @@map("focus_soundscapes")
}

model FocusSession {
  id                         BigInt    @id @default(autoincrement())
  publicId                   String    @unique @map("public_id")
  userId                     BigInt    @map("user_id")
  deedActionId               BigInt?   @map("deed_action_id")
  soundscapeId               BigInt?   @map("soundscape_id")
  targetDurationSeconds      Int       @default(20) @map("target_duration_seconds")
  elapsedSeconds             Int       @default(0) @map("elapsed_seconds")
  completionThresholdPercent Int       @default(100) @map("completion_threshold_percent")
  reducedMotion              Boolean   @default(false) @map("reduced_motion")
  status                     String    @default("started")
  completionIdempotencyKey   String?   @unique @map("completion_idempotency_key")
  startedAt                  DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt                DateTime? @map("completed_at") @db.Timestamptz(6)
  expiresAt                  DateTime  @map("expires_at") @db.Timestamptz(6)
  metadata                   Json      @default("{}")

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  deedAction    DeedAction?      @relation(fields: [deedActionId], references: [id], onDelete: SetNull)
  soundscape    FocusSoundscape? @relation(fields: [soundscapeId], references: [id], onDelete: SetNull)
  reflections   FocusReflection[]
  karmaEvents   KarmaEvent[]

  @@index([userId, startedAt])
  @@index([deedActionId])
  @@index([status, expiresAt])
  @@map("focus_sessions")
}

model FocusReflection {
  id             BigInt    @id @default(autoincrement())
  publicId       String    @unique @map("public_id")
  userId         BigInt    @map("user_id")
  focusSessionId BigInt    @map("focus_session_id")
  mood           String
  body           String?
  visibility     String    @default("private")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusSession FocusSession @relation(fields: [focusSessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([focusSessionId])
  @@map("focus_reflections")
}

model JournalEntry {
  id           BigInt    @id @default(autoincrement())
  publicId     String    @unique @map("public_id")
  userId       BigInt    @map("user_id")
  deedActionId BigInt?   @map("deed_action_id")
  body         String
  visibility   String    @default("private")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deedAction DeedAction? @relation(fields: [deedActionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("journal_entries")
}

model Blessing {
  id               BigInt    @id @default(autoincrement())
  publicId         String    @unique @map("public_id")
  authorUserId     BigInt?   @map("author_user_id")
  body             String
  visibility       String    @default("anonymous")
  reactionCount    BigInt    @default(0) @map("reaction_count")
  moderationStatus String    @default("visible") @map("moderation_status")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  removedAt        DateTime? @map("removed_at") @db.Timestamptz(6)

  author    User?              @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  reactions BlessingReaction[]

  @@index([moderationStatus, createdAt])
  @@index([authorUserId, createdAt])
  @@map("blessings")
}

model BlessingReaction {
  id           BigInt   @id @default(autoincrement())
  publicId     String   @unique @map("public_id")
  blessingId   BigInt   @map("blessing_id")
  userId       BigInt   @map("user_id")
  reactionType String   @map("reaction_type")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  blessing Blessing @relation(fields: [blessingId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blessingId, userId, reactionType])
  @@index([userId, createdAt])
  @@map("blessing_reactions")
}

model DonationCampaign {
  id                 BigInt    @id @default(autoincrement())
  slug               String    @unique
  name               String
  partnerName        String    @map("partner_name")
  category           String
  verificationStatus String    @default("pending_review") @map("verification_status")
  description        String
  targetAmount       Decimal?  @map("target_amount") @db.Decimal(12, 2)
  currentAmount      Decimal   @default(0) @map("current_amount") @db.Decimal(12, 2)
  startsAt           DateTime? @map("starts_at") @db.Timestamptz(6)
  endsAt             DateTime? @map("ends_at") @db.Timestamptz(6)
  status             String    @default("draft")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  mapSpots  MapSpot[]
  donations Donation[]

  @@index([status, startsAt, endsAt])
  @@map("donation_campaigns")
}

model Donation {
  id                BigInt    @id @default(autoincrement())
  publicId          String    @unique @map("public_id")
  userId            BigInt    @map("user_id")
  campaignId        BigInt    @map("campaign_id")
  amount            Decimal   @db.Decimal(12, 2)
  currency          String
  paymentProvider   String?   @map("payment_provider")
  providerPaymentId String?   @map("provider_payment_id")
  paymentStatus     String    @default("pending") @map("payment_status")
  idempotencyKey    String    @unique @map("idempotency_key")
  receiptUrl        String?   @map("receipt_url")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  paidAt            DateTime? @map("paid_at") @db.Timestamptz(6)

  user     User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  campaign DonationCampaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([campaignId, paymentStatus])
  @@map("donations")
}

model SafetyReport {
  id               BigInt    @id @default(autoincrement())
  publicId         String    @unique @map("public_id")
  reporterUserId   BigInt?   @map("reporter_user_id")
  targetType       String    @map("target_type")
  targetPublicId   String    @map("target_public_id")
  reason           String
  moderationStatus String    @default("open") @map("moderation_status")
  moderatorNote    String?   @map("moderator_note")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)

  reporter User? @relation(fields: [reporterUserId], references: [id], onDelete: SetNull)

  @@index([moderationStatus, createdAt])
  @@index([reporterUserId])
  @@map("safety_reports")
}

model Subscription {
  id         BigInt    @id @default(autoincrement())
  publicId   String    @unique @map("public_id")
  userId     BigInt    @map("user_id")
  plan       String
  status     String    @default("trial")
  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  renewsAt   DateTime? @map("renews_at") @db.Timestamptz(6)
  canceledAt DateTime? @map("canceled_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@map("subscriptions")
}
